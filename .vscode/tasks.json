{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm install",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/internal/desktop/frontend"
      },
      "presentation": {
        "clear": true,
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "pnpm run build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/internal/desktop/frontend"
      },
      "presentation": {
        "clear": true,
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "build wails",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/internal/desktop"
      },
      "command": "go",
      "args": [
        "build",
        "-tags",
        "dev",
        "-gcflags",
        "all=-N -l",
        "-o",
        "build/bin/nanci-desktop.exe"
      ],
      "dependsOn": ["pnpm install", "pnpm run build"],
      "problemMatcher": ["$go"]
    },
    {
      "label": "build cli",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "go",
      "args": [
        "build",
        "-gcflags",
        "all=-N -l",
        "-o",
        "bin/nanci.exe",
        "./cmd/nanci"
      ],
      "problemMatcher": ["$go"]
    }
  ]
}
